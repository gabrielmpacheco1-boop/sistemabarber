# ──────────────────────────────────────────────
# AgendaBarber — Variáveis de Ambiente
# Copie este arquivo para .env.local (desenvolvimento)
# Configure no painel da Vercel em Settings > Environment Variables
# ──────────────────────────────────────────────

# SUPABASE
# Encontre em: Supabase Dashboard > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# EVOLUTION API (WhatsApp)
# Encontre em: painel do Railway ou servidor onde a Evolution API está rodando
EVOLUTION_API_URL=https://sua-evolution-api.railway.app
EVOLUTION_API_KEY=sua-chave-da-evolution-api
EVOLUTION_INSTANCE=nome-da-instancia

# VERCEL (preenchido automaticamente em produção, necessário para auto-referência)
# VERCEL_URL é injetado automaticamente pela Vercel — não precisa definir manualmente
# VERCEL_URL=seu-projeto.vercel.app
